{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Validate",
      "skipFiles": ["<node_internals>/**"],
      "program": "${workspaceFolder}/dist/cli.js",
      "args": ["validate", "--verbose"],
      "preLaunchTask": "npm: build",
      "outFiles": ["${workspaceFolder}/dist/**/*.js"]
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Validate and update",
      "skipFiles": ["<node_internals>/**"],
      "program": "${workspaceFolder}/dist/cli.js",
      "args": ["validate", "--verbose", "--update"],
      "preLaunchTask": "npm: build",
      "outFiles": ["${workspaceFolder}/dist/**/*.js"]
    },
    {
      "type": "node-terminal",
      "request": "launch",
      "name": "Legacy (ESLint)",
      "command": "npx eslint -c eslint.config.mjs \"**/*.{ts,tsx,mts,js,jsx,mjs}\" --format=json | node dist/cli.js legacy-errors --verbose",
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "npm: build",
      "skipFiles": ["<node_internals>/**"],
      "outFiles": ["${workspaceFolder}/dist/**/*.js"]
    },
    {
      "type": "node-terminal",
      "request": "launch",
      "name": "Legacy (Oxlint)",
      "command": "npx oxlint -c oxlint.config.ts --type-aware --format=json | node dist/cli.js legacy-errors --verbose",
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "npm: build",
      "skipFiles": ["<node_internals>/**"],
      "outFiles": ["${workspaceFolder}/dist/**/*.js"]
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Tests",
      "skipFiles": ["<node_internals>/**"],
      "program": "${workspaceFolder}/node_modules/vitest/vitest.mjs",
      "args": ["run"],
      "autoAttachChildProcesses": true,
      "smartStep": true,
      "console": "integratedTerminal"
    }
  ]
}
