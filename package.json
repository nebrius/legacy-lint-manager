{
  "name": "legacy-lint-manager",
  "version": "1.0.0",
  "description": "A monorepo-aware tool for enabling ESLint/Oxlint rules on codebases with legacy errors",
  "homepage": "https://github.com/nebrius/legacy-lint-manager#readme",
  "bugs": {
    "url": "https://github.com/nebrius/legacy-lint-manager/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nebrius/legacy-lint-manager.git"
  },
  "license": "MIT",
  "author": "Bryan Hughes <bryan@nebri.us>",
  "type": "module",
  "main": "dist/api.js",
  "bin": {
    "legacy-lint-manager": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js",
    "lint": "npm run lint:eslint && npm run lint:oxlint",
    "lint:eslint": "eslint --report-unused-disable-directives -c eslint.config.mjs \"**/*.{ts,tsx,mts,js,jsx,mjs}\"",
    "lint:eslint:fix": "eslint --fix -c eslint.config.mjs \"**/*.{js,jsx,mjs,ts,tsx,mts}\"",
    "lint:oxlint": "oxlint -c oxlint.config.ts --type-aware",
    "start": "node dist/cli.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@commander-js/extra-typings": "^15.0.0",
    "commander": "^15.0.0",
    "ignore": "^7.0.5",
    "nanoid": "^5.1.15",
    "oxc-parser": "^0.137.0",
    "typebox": "^1.3.0"
  },
  "devDependencies": {
    "@eslint/config-helpers": "^0.6.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^17.7.0",
    "import-integrity-lint": "^1.1.3",
    "oxlint": "^1.71.0",
    "oxlint-tsgolint": "^0.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  }
}
